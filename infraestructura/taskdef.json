{
  "family": "murano-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::656751413705:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "murano-web",
      "image": "656751413705.dkr.ecr.us-east-1.amazonaws.com/murano-voley-connect:1.0",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ]
}
